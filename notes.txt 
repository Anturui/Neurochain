
use reqwest::blocking::Client;
use serde::{Deserialize, Serialize};
use std::time::Duration;

#[derive(Serialize)]
struct Request {
    model: String,
    prompt: String,
    stream: bool,
}

#[derive(Deserialize)]
struct Response {
    response: String,
}

pub struct Student {
    client: Client,
}

impl Student {
    pub fn new() -> anyhow::Result<Self> {
        let client = Client::builder()
            .timeout(Duration::from_secs(120)) // 2 минуты вместо 30 сек
            .build()?;
        
        Ok(Self { client })
    }
    
    pub fn generate(&self, prompt: &str) -> anyhow::Result<String> {
        let res = self.client
            .post("http://localhost:11434/api/generate")
            .json(&Request {
                model: "codellama:7b-code".to_string(),
                prompt: prompt.to_string(),
                stream: false,
            })
            .send()?
            .json::<Response>()?;
            
        Ok(res.response)
    }
}












